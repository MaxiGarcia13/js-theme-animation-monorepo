{
  "name": "js-theme-animation-monorepo",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Smooth, dependency-free theme transitions using the native View Transitions API. Just clean, high-performance animations built straight into the browser.",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "homepage": "https://github.com/MaxiGarcia13/js-theme-animation-monorepo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/js-theme-animation.git"
  },
  "bugs": {
    "url": "https://github.com/MaxiGarcia13/js-theme-animation/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "theme",
    "transition",
    "view transitions",
    "view transitions api",
    "utility",
    "library",
    "css",
    "javascript",
    "web",
    "dark mode",
    "light mode",
    "dark theme",
    "light theme"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx dev @maxigarcia/theme-transitions-app",
    "preview": "nx preview @maxigarcia/theme-transitions-app",
    "lint": "eslint packages",
    "lint:fix": "eslint --fix packages",
    "version:app": "nx release --projects=@maxigarcia/theme-transitions-app --skip-publish",
    "release": "nx release publish --projects=@maxigarcia/theme-transitions --access public",
    "clean": "npm run phoenix -w @maxigarcia/theme-transitions && npm run phoenix -w @maxigarcia/theme-transitions-app",
    "phoenix": "nx reset && npm run clean && npm i && npm run build"
  },
  "devDependencies": {
    "@maxigarcia/eslint-config": "^1.5.0",
    "@nx/js": "^22.7.2",
    "@types/node": "^25.9.1",
    "nx": "22.7.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "vite": "^7"
  }
}
