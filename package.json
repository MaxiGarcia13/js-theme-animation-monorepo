{
  "name": "js-theme-animation-monorepo",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Smooth, dependency-free theme transitions using the native View Transitions API. Just clean, high-performance animations built straight into the browser.",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "homepage": "https://github.com/MaxiGarcia13/js-theme-animation#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/js-theme-animation.git"
  },
  "bugs": {
    "url": "https://github.com/MaxiGarcia13/js-theme-animation/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx dev @maxigarcia/js-theme-animation-app",
    "preview": "nx preview @maxigarcia/js-theme-animation-app",
    "lint": "eslint packages",
    "lint:fix": "eslint --fix packages",
    "version-packages": "nx release --skip-publish",
    "release": "nx release publish --projects=@maxigarcia/js-theme-animation --first-release --access public",
    "clean": "npm run phoenix -w @maxigarcia/js-theme-animation && npm run phoenix -w @maxigarcia/js-theme-animation-app",
    "phoenix": "npm run clean && npm i && npm run build"
  },
  "devDependencies": {
    "@maxigarcia/eslint-config": "^1.5.0",
    "@nx/js": "^22.7.2",
    "@types/node": "^25.9.1",
    "nx": "22.7.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "vite": "^7"
  }
}
