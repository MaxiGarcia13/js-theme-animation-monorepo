{
  "name": "js-theme-animation-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "homepage": "https://github.com/MaxiGarcia13/js-theme-animation#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/js-theme-animation.git"
  },
  "bugs": {
    "url": "https://github.com/MaxiGarcia13/js-theme-animation/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @maxigarcia/js-theme-animation && npm run build -w app",
    "dev": "npm run dev -w app",
    "lint": "eslint packages",
    "lint:fix": "eslint --fix packages",
    "prepublish:npm": "npm run build -w @maxigarcia/js-theme-animation",
    "publish:npm": "npm publish -w @maxigarcia/js-theme-animation --access public",
    "clean": "npm run phoenix -w @maxigarcia/js-theme-animation && npm run phoenix -w app",
    "phoenix": "npm run clean && npm i && npm run build"
  },
  "devDependencies": {
    "@maxigarcia/eslint-config": "^1.5.0",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
