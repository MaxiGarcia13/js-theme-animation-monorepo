{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{projectRoot}/dist", "{projectRoot}/.astro"]
    },
    "lint": {
      "cache": true
    },
    "dev": {
      "continuous": true
    }
  },
  "release": {
    "projects": [
      "@maxigarcia/js-theme-animation",
      "@maxigarcia/js-theme-animation-app"
    ],
    "projectsRelationship": "independent",
    "releaseTag": {
      "pattern": "{projectName}@{version}"
    },
    "version": {
      "conventionalCommits": true,
      "preVersionCommand": "npx nx run-many -t build -p @maxigarcia/js-theme-animation,@maxigarcia/js-theme-animation-app"
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": true
    },
    "git": {
      "commit": true,
      "tag": true,
      "commitMessage": "chore: version packages"
    }
  },
  "analytics": false
}
