---
import type { HTMLAttributes } from 'astro/types';
import { INSTALL_NAV_ITEM } from '@/consts/navigation';
import { INSTALL_GUIDE_CARD } from '@/consts/install-guide';
import GuideCard from '../guide/guide-card.astro';
import GuideNavSection from '../guide/guide-nav-section.astro';

interface Props extends HTMLAttributes<'div'> {}

const { class: className, ...rest } = Astro.props;
---

<GuideNavSection
  {...rest}
  navItem={INSTALL_NAV_ITEM}
  class:list={['gap-4', className]}
>
  <GuideCard guide={INSTALL_GUIDE_CARD} />
</GuideNavSection>
