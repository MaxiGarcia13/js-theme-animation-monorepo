---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  label?: string;
  code: string;
}

const { label, code, class: className, ...rest } = Astro.props;
---

<div
  {...rest}
  class:list={['overflow-hidden rounded-md border border-surface-border', className]}
>
  {
    label && (
      <div class="border-b border-surface-border bg-muted/60 px-4 py-2 text-xs font-medium tracking-wide text-muted-foreground uppercase">
        {label}
      </div>
    )
  }
  <pre
    class="overflow-x-auto bg-muted/30 p-4 text-sm leading-relaxed text-foreground"
  ><code class="font-mono">{code}</code></pre>
</div>
