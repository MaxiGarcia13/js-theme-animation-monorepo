---
import type { HTMLAttributes } from 'astro/types';
import PageTurnDemoCard from './page-turn-demo-card.astro';
import CircularRevealDemoCard from './circular-reveal-demo-card.astro';
import FallDemoCard from './fall-demo-card.astro';
import SweepRevealDemoCard from './sweep-reveal-demo-card.astro';
import GuideNavSection from '../guide/guide-nav-section.astro';
import { DEMOS_NAV_ITEM } from '@/consts/navigation';

interface Props extends HTMLAttributes<'section'> {}

const { class: className, ...rest } = Astro.props;
---

<GuideNavSection
  {...rest}
  navItem={DEMOS_NAV_ITEM}
  class:list={['gap-6', className]}
>
  <section
    {...rest}
    id="demos"
    data-nav-section="demos"
    class:list={[
      'scroll-mt-24 grid grid-cols-1 gap-6 sm:grid-cols-2 flex-wrap',
      className,
    ]}
    aria-label="Animation demos"
  >
    <CircularRevealDemoCard class="flex-1" />
    <SweepRevealDemoCard class="flex-1" />
    <FallDemoCard class="flex-1" />
    <PageTurnDemoCard class="flex-1" />
  </section>
</GuideNavSection>
