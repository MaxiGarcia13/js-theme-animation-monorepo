---
import { GITHUB_JS_THEME_ANIMATION_URL } from '../../constants/app';
import AnimationDemoCard from './animation-demo-card.astro';
import Select from './select.astro';
import ThemeToggleButton from './theme-toggle-button.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const GITHUB_SWEEP_REVEAL_URL = `${GITHUB_JS_THEME_ANIMATION_URL}/src/sweep-reveal`;

const sweepDirections = [
  { value: 'up', label: 'Up' },
  { value: 'down', label: 'Down' },
  { value: 'left', label: 'Left' },
  { value: 'right', label: 'Right' },
  { value: 'corner-top-left', label: 'Corner Top Left' },
  { value: 'corner-top-right', label: 'Corner Top Right' },
  { value: 'corner-bottom-left', label: 'Corner Bottom Left' },
  { value: 'corner-bottom-right', label: 'Corner Bottom Right' },
];
---

<AnimationDemoCard
  data-sweep-reveal-demo
  title="Sweep Reveal"
  description="The new theme sweeps in from the chosen edge."
  badge="Live demo"
  githubUrl={GITHUB_SWEEP_REVEAL_URL}
  class:list={[className]}
>
  <div class="flex-1 inline-flex items-center justify-center gap-4">
    <ThemeToggleButton id="sweep" />

    <Select
      id="sweep-direction"
      data-sweep-direction
      options={sweepDirections}
      class="h-full max-w-24"
    />
  </div>
</AnimationDemoCard>

<script>
  import { onSweepRevealAnimation } from '@maxigarcia/js-theme-animation';
  import { toggleTheme } from '../utils/toggle-theme';

  type SweepDirection = 'up' | 'down' | 'left' | 'right';

  const demo = document.querySelector('[data-sweep-reveal-demo]');
  const button = demo?.querySelector<HTMLButtonElement>(
    '[data-theme-toggle-button]',
  );
  const directionSelect = demo?.querySelector<HTMLSelectElement>(
    '[data-sweep-direction]',
  );

  if (button && directionSelect) {
    button.addEventListener('click', () => {
      const direction = directionSelect.value as SweepDirection;
      onSweepRevealAnimation(() => toggleTheme(button), direction);
    });
  }
</script>
