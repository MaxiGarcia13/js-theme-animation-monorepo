---
import { GITHUB_CIRCULAR_REVEAL_URL } from '@/consts/app';
import AnimationDemoCard from './animation-demo-card.astro';
import Checkbox from './checkbox.astro';
import Select from './select.astro';
import ThemeToggleButton from './theme-toggle-button.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const blurAmountOptions = [
  { value: '4px', label: '4px' },
  { value: '8px', label: '8px' },
  { value: '12px', label: '12px' },
  { value: '16px', label: '16px' },
  { value: '24px', label: '24px' },
  { value: '32px', label: '32px' },
  { value: '40px', label: '40px' },
  { value: '60px', label: '60px' },
];
---

<AnimationDemoCard
  data-circular-reveal-demo
  title="Circular Reveal"
  description="A radial clip-path expands from the click origin, sweeping the new theme into view."
  badge="Live demo"
  githubUrl={GITHUB_CIRCULAR_REVEAL_URL}
  class:list={[className]}
>
  <div class="inline-flex flex-1 flex-wrap items-center justify-center gap-4">
    <ThemeToggleButton id="circular" />

    <Checkbox id="circular-blur" data-circular-blur label="Blur" />

    <Select
      id="circular-blur-amount"
      data-circular-blur-amount
      options={blurAmountOptions}
      value="12px"
      class="h-full max-w-24"
    />
  </div>
</AnimationDemoCard>

<script>
  import { onCircularRevealAnimation } from '@maxigarcia/js-theme-animation';
  import { toggleTheme } from '../utils/toggle-theme';

  const demo = document.querySelector('[data-circular-reveal-demo]');
  const button = demo?.querySelector<HTMLButtonElement>(
    '[data-theme-toggle-button]',
  );
  const blurCheckbox = demo?.querySelector<HTMLInputElement>(
    '[data-circular-blur]',
  );
  const blurAmountSelect = demo?.querySelector<HTMLSelectElement>(
    '[data-circular-blur-amount]',
  );

  if (button && blurCheckbox && blurAmountSelect) {
    button.addEventListener('click', (event) => {
      onCircularRevealAnimation(() => toggleTheme(button), event, {
        blurCircle: blurCheckbox.checked,
        blurAmount: blurAmountSelect.value,
      });
    });
  }
</script>
