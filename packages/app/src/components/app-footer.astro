---
import type { HTMLAttributes } from 'astro/types';
import GithubIcon from './icons/github.astro';
import { GITHUB_JS_THEME_ANIMATION_URL } from '@/consts/app';
import packageJson from '../../package.json';
import packageJsonThemeTransitions from '../../../theme-transitions/package.json';

interface Props extends HTMLAttributes<'footer'> {}

const { class: className, ...rest } = Astro.props;
---

<footer
  {...rest}
  class:list={[
    'text-center inline-flex justify-center items-center mx-auto gap-2 text-sm text-muted-foreground w-full',
    className,
  ]}
>
  <a
    href={GITHUB_JS_THEME_ANIMATION_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 transition-colors hover:text-foreground"
  >
    <GithubIcon id="github-icon-footer" class="size-4 shrink-0" />
    {packageJsonThemeTransitions.name}
  </a>
  - APP v{packageJson.version}
</footer>
