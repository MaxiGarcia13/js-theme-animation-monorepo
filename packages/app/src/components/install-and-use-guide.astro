---
import type { HTMLAttributes } from 'astro/types';
import {
  installGuideCard,
  usageGuideCards,
} from '@/consts/install-and-use-guide';
import UsageGuideCard from './usage-guide-card.astro';

interface Props extends HTMLAttributes<'section'> {}

const { class: className, ...rest } = Astro.props;
---

<section
  {...rest}
  class:list={['flex flex-col gap-10', className]}
  aria-labelledby="install-and-use-heading"
>
  <header class="space-y-2 text-center sm:text-left">
    <h2
      id="install-and-use-heading"
      class="text-2xl font-semibold tracking-tight text-foreground"
    >
      Install &amp; use
    </h2>
    <p
      class="mx-auto max-w-2xl text-sm leading-relaxed text-muted-foreground sm:mx-0"
    >
      Install the package, then pick an animation helper. Each card includes the
      CSS setup and JavaScript usage for that technique.
    </p>
  </header>

  <div class="flex flex-col gap-10">
    <div class="flex flex-col gap-4" aria-labelledby="install-heading">
      <h3
        id="install-heading"
        class="text-sm font-semibold tracking-wide text-muted-foreground uppercase"
      >
        Install
      </h3>
      <UsageGuideCard guide={installGuideCard} />
    </div>

    <div class="flex flex-col gap-4" aria-labelledby="use-heading">
      <h3
        id="use-heading"
        class="text-sm font-semibold tracking-wide text-muted-foreground uppercase"
      >
        Use
      </h3>
      <div class="space-y-6">
        {usageGuideCards.map((guide) => <UsageGuideCard guide={guide} />)}
      </div>
    </div>
  </div>
</section>
