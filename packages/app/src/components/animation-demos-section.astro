---
import type { HTMLAttributes } from 'astro/types';
import CircularRevealDemoCard from './circular-reveal-demo-card.astro';
import SweepRevealDemoCard from './sweep-reveal-demo-card.astro';
import GuideNavSection from './guide-nav-section.astro';
import { DEMOS_NAV_ITEM } from '@/consts/app-nav';

interface Props extends HTMLAttributes<'section'> {}

const { class: className, ...rest } = Astro.props;
---

<GuideNavSection
  {...rest}
  navItem={DEMOS_NAV_ITEM}
  class:list={['gap-6', className]}
>
  <section
    {...rest}
    id="demos"
    data-nav-section="demos"
    class:list={[
      'scroll-mt-24 flex flex-col gap-6 sm:flex-row flex-wrap',
      className,
    ]}
    aria-label="Animation demos"
  >
    <CircularRevealDemoCard class="flex-1" />
    <SweepRevealDemoCard class="flex-1" />
  </section>
</GuideNavSection>
