---
import MoonIcon from "./icons/moon.astro";
import SunIcon from "./icons/sun.astro";
---

<button
  type="button"
  data-theme-toggle
  class="rounded p-3 bg-gray-200 dark:bg-gray-800 cursor-pointer flex items-center gap-3"
>
  <MoonIcon id="moon-icon" class="block size-6" />
  <SunIcon id="sun-icon" class="hidden size-6" />
  <span>Toggle theme</span>
</button>

<script>
  import {
    circularRevealChange,
    type ThemeRevealOrigin,
  } from "@maxigarcia/js-theme-animation";

  function toggleTheme() {
    const isDark = document.documentElement.classList.contains("dark");

    document.documentElement.classList.toggle("dark", !isDark);

    const moonIcon = document.getElementById("moon-icon");
    const sunIcon = document.getElementById("sun-icon");

    moonIcon?.classList.toggle("hidden", !isDark);
    moonIcon?.classList.toggle("block", isDark);

    sunIcon?.classList.toggle("block", !isDark);
    sunIcon?.classList.toggle("hidden", isDark);
  }

  document
    .querySelector("[data-theme-toggle]")
    ?.addEventListener("click", (event) => {
      circularRevealChange(toggleTheme, event as unknown as ThemeRevealOrigin);
    });
</script>
