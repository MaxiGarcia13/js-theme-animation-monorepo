---
import MoonIcon from './icons/moon.astro';
import SunIcon from './icons/sun.astro';
import Button from './button.astro';

interface Props {
  id?: string;
}

const { id = 'default' } = Astro.props;
---

<Button data-theme-toggle-button>
  <span data-theme-icon="moon" class="contents">
    <MoonIcon id={`moon-icon-${id}`} class="hidden size-5 shrink-0" />
  </span>
  <span data-theme-icon="sun" class="contents">
    <SunIcon id={`sun-icon-${id}`} class="block size-5 shrink-0" />
  </span>
  <span>Toggle dark mode</span>
</Button>
