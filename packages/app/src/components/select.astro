---
import type { HTMLAttributes } from 'astro/types';
import ChevronDownIcon from './icons/chevron-down.astro';

export interface SelectOption {
  value: string;
  label: string;
}

interface Props extends HTMLAttributes<'select'> {
  options: SelectOption[];
}

const { options, class: className, id, ...rest } = Astro.props;

const chevronId = id ? `${id}-chevron` : 'select-chevron';
---

<div class:list={['relative inline-flex', className]}>
  <select
    id={id}
    class:list={[
      'cursor-pointer appearance-none rounded-xl border border-surface-border bg-surface py-3 pl-5 pr-10 text-sm font-medium text-foreground shadow-sm transition-[box-shadow] duration-200 hover:shadow-md hover:shadow-glow/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent',
      'h-full w-full min-w-0',
    ]}
    {...rest}
  >
    {
      options.map((option) => (
        <option value={option.value}>{option.label}</option>
      ))
    }
  </select>
  <span
    class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-foreground"
    aria-hidden="true"
  >
    <ChevronDownIcon id={chevronId} class="size-5 shrink-0" />
  </span>
</div>
